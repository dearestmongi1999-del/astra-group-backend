APP_NAME=Astra Group API
APP_ENV=production
APP_DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE

ALLOWED_ORIGINS=https://astragroupltd.com,https://www.astragroupltd.com,https://astra-group.vercel.app

JWT_SECRET_KEY=replace_with_new_secure_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_EMAIL=astragroup47@gmail.com
ADMIN_PHONE=255XXXXXXXXX

EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=astragroup47@gmail.com
EMAIL_PASSWORD=replace_with_new_gmail_app_password
EMAIL_FROM=astragroup47@gmail.com
EMAIL_FROM_NAME=Astra Group
EMAIL_USE_TLS=true
EMAIL_TIMEOUT_SECONDS=30

WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=manual
WHATSAPP_BUSINESS_NUMBER=255XXXXXXXXX

UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

DEFAULT_CURRENCY=TZS
DEFAULT_SERVICE_TYPES=cleaning,fumigation

LOG_LEVEL=INFO
